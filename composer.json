{
    "name": "pressgang-wp/bosun",
    "description": "WP-CLI package that composes AI agent guidelines and skills for PressGang WordPress themes — the bosun pipes the conventions to the crew.",
    "type": "wp-cli-package",
    "license": "MIT",
    "authors": [
        {
            "name": "Benedict Wallis",
            "email": "ben@benedict-wallis.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PressGang\\Bosun\\": "src/"
        },
        "files": [
            "bosun.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PressGang\\Bosun\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
